{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Virtual VR Emulator",
  "version": "0.1.0",
  "identifier": "com.sasaken.vvre",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1410",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Virtual VR Emulator",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../../driver/output/vvre/": "vvre/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
